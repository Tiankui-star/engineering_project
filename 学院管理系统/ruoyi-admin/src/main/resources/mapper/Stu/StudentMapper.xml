<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.Stu.mapper.StudentMapper">
    
    <resultMap type="Student" id="StudentResult">
        <result property="studentId"    column="student_id"    />
        <result property="studentNumber"    column="student_number"    />
        <result property="name"    column="name"    />
        <result property="birthDate"    column="birth_date"    />
        <result property="gender"    column="gender"    />
        <result property="idCard"    column="id_card"    />
        <result property="departmentId"    column="department_id"    />
        <result property="enrollmentDate"    column="enrollment_date"    />
        <result property="status"    column="status"    />
        <result property="awardCount"    column="award_count"    />
        <result property="paperCount"    column="paper_count"    />
        <result property="projectCount"    column="project_count"    />
    </resultMap>

    <resultMap id="StudentStudentAwardResult" type="Student" extends="StudentResult">
        <collection property="studentAwardList" ofType="StudentAward" column="student_id" select="selectStudentAwardList" />
    </resultMap>

    <resultMap type="StudentAward" id="StudentAwardResult">
        <result property="awardId"    column="award_id"    />
        <result property="awardName"    column="award_name"    />
        <result property="description"    column="description"    />
        <result property="awardDate"    column="award_date"    />
        <result property="awardLevel"    column="award_level"    />
        <result property="issuingOrganization"    column="issuing_organization"    />
        <result property="studentId"    column="student_id"    />
        <result property="supervisorFacultyId"    column="supervisor_faculty_id"    />
    </resultMap>

    <sql id="selectStudentVo">
        select student_id, student_number, name, birth_date, gender, id_card, department_id, enrollment_date, status, award_count, paper_count, project_count from student
    </sql>

    <select id="selectStudentList" parameterType="Student" resultMap="StudentResult">
        <include refid="selectStudentVo"/>
        <where>  
            <if test="studentId != null "> and student_id = #{studentId}</if>
            <if test="studentNumber != null  and studentNumber != ''"> and student_number = #{studentNumber}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="birthDate != null "> and birth_date = #{birthDate}</if>
            <if test="gender != null  and gender != ''"> and gender = #{gender}</if>
            <if test="idCard != null  and idCard != ''"> and id_card = #{idCard}</if>
            <if test="departmentId != null "> and department_id = #{departmentId}</if>
            <if test="enrollmentDate != null "> and enrollment_date = #{enrollmentDate}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="awardCount != null "> and award_count = #{awardCount}</if>
            <if test="paperCount != null "> and paper_count = #{paperCount}</if>
            <if test="projectCount != null "> and project_count = #{projectCount}</if>
        </where>
    </select>
    
    <select id="selectStudentByStudentId" parameterType="Long" resultMap="StudentStudentAwardResult">
        select student_id, student_number, name, birth_date, gender, id_card, department_id, enrollment_date, status, award_count, paper_count, project_count
        from student
        where student_id = #{studentId}
    </select>

    <select id="selectStudentByStudentNumber" parameterType="String" resultMap="StudentResult">
        select student_id, student_number, name, birth_date, gender, id_card, department_id, enrollment_date, status, award_count, paper_count, project_count
        from student
        where student_number = #{studentNumber}
    </select>

    <select id="selectStudentAwardList" resultMap="StudentAwardResult">
        select award_id, award_name, description, award_date, award_level, issuing_organization, student_id, supervisor_faculty_id
        from student_award
        where student_id = #{student_id}
    </select>

    <insert id="insertStudent" parameterType="Student">
        insert into student
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="studentNumber != null and studentNumber != ''">student_number,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="gender != null">gender,</if>
            <if test="idCard != null">id_card,</if>
            <if test="departmentId != null">department_id,</if>
            <if test="enrollmentDate != null">enrollment_date,</if>
            <if test="status != null">status,</if>
            <if test="awardCount != null">award_count,</if>
            <if test="paperCount != null">paper_count,</if>
            <if test="projectCount != null">project_count,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="studentNumber != null and studentNumber != ''">#{studentNumber},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="gender != null">#{gender},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="departmentId != null">#{departmentId},</if>
            <if test="enrollmentDate != null">#{enrollmentDate},</if>
            <if test="status != null">#{status},</if>
            <if test="awardCount != null">#{awardCount},</if>
            <if test="paperCount != null">#{paperCount},</if>
            <if test="projectCount != null">#{projectCount},</if>
         </trim>
    </insert>

    <update id="updateStudent" parameterType="Student">
        update student
        <trim prefix="SET" suffixOverrides=",">
            <if test="studentNumber != null and studentNumber != ''">student_number = #{studentNumber},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="departmentId != null">department_id = #{departmentId},</if>
            <if test="enrollmentDate != null">enrollment_date = #{enrollmentDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="awardCount != null">award_count = #{awardCount},</if>
            <if test="paperCount != null">paper_count = #{paperCount},</if>
            <if test="projectCount != null">project_count = #{projectCount},</if>
        </trim>
        where student_id = #{studentId}
    </update>

    <delete id="deleteStudentByStudentId" parameterType="Long">
        delete from student where student_id = #{studentId}
    </delete>

    <delete id="deleteStudentByStudentIds" parameterType="String">
        delete from student where student_id in 
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>
    
    <delete id="deleteStudentAwardByStudentIds" parameterType="String">
        delete from student_award where student_id in 
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>

    <delete id="deleteStudentAwardByStudentId" parameterType="Long">
        delete from student_award where student_id = #{studentId}
    </delete>

    <insert id="batchStudentAward">
        insert into student_award( award_id, award_name, description, award_date, award_level, issuing_organization, student_id, supervisor_faculty_id) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.awardId}, #{item.awardName}, #{item.description}, #{item.awardDate}, #{item.awardLevel}, #{item.issuingOrganization}, #{item.studentId}, #{item.supervisorFacultyId})
        </foreach>
    </insert>

    <update id="updateStudentNumber">
        update student set student_number = #{newStudentNumber} where student_id = #{studentId}
    </update>
</mapper>