<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.Project.mapper.ResearchProjectMapper">
    
    <resultMap type="ResearchProject" id="ResearchProjectResult">
        <result property="projectId"    column="project_id"    />
        <result property="projectCode"    column="project_code"    />
        <result property="projectName"    column="project_name"    />
        <result property="description"    column="description"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="projectLevel"    column="project_level"    />
        <result property="projectStatus"    column="project_status"    />
        <result property="leaderType"    column="leader_type"    />
        <result property="leaderId"    column="leader_id"    />
        <result property="leaderName"    column="leader_name"    />
        <result property="departmentId"    column="department_id"    />
        <result property="departmentName"    column="department_name"    />
    </resultMap>

    <resultMap id="ResearchProjectProjectOutputResult" type="ResearchProject" extends="ResearchProjectResult">
        <collection property="projectOutputList" ofType="ProjectOutput" column="project_id" select="selectProjectOutputList" />
        <collection property="projectMemberList" ofType="ProjectMember" column="project_id" select="selectProjectMemberList" />
        <collection property="fundingRecordList" ofType="FundingRecord" column="project_id" select="selectFundingRecordList" />
    </resultMap>

    <resultMap type="ProjectOutput" id="ProjectOutputResult">
        <result property="projectOutputId"    column="project_output_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="outputType"    column="output_type"    />
        <result property="outputId"    column="output_id"    />
        <result property="outputDate"    column="output_date"    />
        <result property="contributionDescription"    column="contribution_description"    />
        <result property="paperTitle"    column="paper_title"    />
        <result property="patentName"    column="patent_name"    />
    </resultMap>

    <resultMap type="ProjectMember" id="ProjectMemberResult">
        <result property="memberId"    column="member_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="memberType"    column="member_type"    />
        <result property="userId"    column="user_id"    />
        <result property="roleType"    column="role_type"    />
        <result property="roleDescription"    column="role_description"    />
        <result property="joinDate"    column="join_date"    />
        <result property="leaveDate"    column="leave_date"    />
        <result property="contributionPercent"    column="contribution_percent"    />
        <result property="memberName"    column="member_name"    />
    </resultMap>

    <resultMap type="FundingRecord" id="FundingRecordResult">
        <result property="fundingId"    column="funding_id"    />
        <result property="projectId"    column="project_id"    />
        <result property="amount"    column="amount"    />
        <result property="allocationDate"    column="allocation_date"    />
        <result property="fundingSource"    column="funding_source"    />
        <result property="fundingType"    column="funding_type"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectResearchProjectVo">
        select 
            rp.project_id, rp.project_code, rp.project_name, rp.description, 
            rp.start_date, rp.end_date, rp.project_level, rp.project_status, 
            rp.leader_type, rp.leader_id, rp.department_id,
            case 
                when rp.leader_type = 'FACULTY' then f.name
                when rp.leader_type = 'STUDENT' then s.name
                else null
            end as leader_name,
            d.department_name
        from research_project rp
        left join faculty f on rp.leader_id = f.faculty_id and rp.leader_type = 'FACULTY'
        left join student s on rp.leader_id = s.student_id and rp.leader_type = 'STUDENT'
        left join department d on rp.department_id = d.department_id
    </sql>

    <select id="selectResearchProjectList" parameterType="ResearchProject" resultMap="ResearchProjectResult">
        <include refid="selectResearchProjectVo"/>
        <where>  
            <if test="projectCode != null  and projectCode != ''"> and project_code = #{projectCode}</if>
            <if test="projectName != null  and projectName != ''"> and project_name like concat('%', #{projectName}, '%')</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="startDate != null "> and start_date = #{startDate}</if>
            <if test="endDate != null "> and end_date = #{endDate}</if>
            <if test="projectLevel != null  and projectLevel != ''"> and project_level = #{projectLevel}</if>
            <if test="projectStatus != null  and projectStatus != ''"> and project_status = #{projectStatus}</if>
            <if test="leaderType != null  and leaderType != ''"> and leader_type = #{leaderType}</if>
            <if test="leaderId != null "> and leader_id = #{leaderId}</if>
            <if test="departmentId != null "> and department_id = #{departmentId}</if>
        </where>
    </select>
    
    <select id="selectResearchProjectByProjectId" parameterType="Long" resultMap="ResearchProjectProjectOutputResult">
        <include refid="selectResearchProjectVo"/>
        where rp.project_id = #{projectId}
    </select>

    <select id="selectProjectOutputList" resultMap="ProjectOutputResult">
        select po.project_output_id, po.project_id, po.output_type, po.output_id, po.output_date, po.contribution_description,
               ap.paper_title,
               p.patent_name
        from project_output po
        left join academic_paper ap on po.output_type = 'PAPER' and po.output_id = ap.paper_id
        left join patent p on po.output_type = 'PATENT' and po.output_id = p.patent_id
        where po.project_id = #{project_id}
    </select>

    <select id="selectProjectMemberList" resultMap="ProjectMemberResult">
        select pm.member_id, pm.project_id, pm.member_type, pm.user_id, pm.role_type, pm.role_description, pm.join_date, pm.leave_date, pm.contribution_percent,
               case 
                   when pm.member_type = 'FACULTY' then f.name
                   when pm.member_type = 'STUDENT' then s.name
                   else null
               end as member_name
        from project_member pm
        left join faculty f on pm.member_type = 'FACULTY' and pm.user_id = f.faculty_id
        left join student s on pm.member_type = 'STUDENT' and pm.user_id = s.student_id
        where pm.project_id = #{project_id}
    </select>

    <select id="selectFundingRecordList" resultMap="FundingRecordResult">
        select funding_id, project_id, amount, allocation_date, funding_source, funding_type, status
        from funding_record
        where project_id = #{project_id}
    </select>

    <insert id="insertResearchProject" parameterType="ResearchProject" useGeneratedKeys="true" keyProperty="projectId">
        insert into research_project
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectCode != null and projectCode != ''">project_code,</if>
            <if test="projectName != null and projectName != ''">project_name,</if>
            <if test="description != null">description,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="projectLevel != null">project_level,</if>
            <if test="projectStatus != null">project_status,</if>
            <if test="leaderType != null and leaderType != ''">leader_type,</if>
            <if test="leaderId != null">leader_id,</if>
            <if test="departmentId != null">department_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectCode != null and projectCode != ''">#{projectCode},</if>
            <if test="projectName != null and projectName != ''">#{projectName},</if>
            <if test="description != null">#{description},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="projectLevel != null">#{projectLevel},</if>
            <if test="projectStatus != null">#{projectStatus},</if>
            <if test="leaderType != null and leaderType != ''">#{leaderType},</if>
            <if test="leaderId != null">#{leaderId},</if>
            <if test="departmentId != null">#{departmentId},</if>
         </trim>
    </insert>

    <update id="updateResearchProject" parameterType="ResearchProject">
        update research_project
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectCode != null and projectCode != ''">project_code = #{projectCode},</if>
            <if test="projectName != null and projectName != ''">project_name = #{projectName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="projectLevel != null">project_level = #{projectLevel},</if>
            <if test="projectStatus != null">project_status = #{projectStatus},</if>
            <if test="leaderType != null and leaderType != ''">leader_type = #{leaderType},</if>
            <if test="leaderId != null">leader_id = #{leaderId},</if>
            <if test="departmentId != null">department_id = #{departmentId},</if>
        </trim>
        where project_id = #{projectId}
    </update>

    <delete id="deleteResearchProjectByProjectId" parameterType="Long">
        delete from research_project where project_id = #{projectId}
    </delete>

    <delete id="deleteResearchProjectByProjectIds" parameterType="String">
        delete from research_project where project_id in 
        <foreach item="projectId" collection="array" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </delete>
    
    <delete id="deleteProjectOutputByProjectIds" parameterType="String">
        delete from project_output where project_id in 
        <foreach item="projectId" collection="array" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </delete>

    <delete id="deleteProjectOutputByProjectId" parameterType="Long">
        delete from project_output where project_id = #{projectId}
    </delete>

    <insert id="batchProjectOutput">
        insert into project_output( project_output_id, project_id, output_type, output_id, output_date, contribution_description) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.projectOutputId}, #{item.projectId}, #{item.outputType}, #{item.outputId}, #{item.outputDate}, #{item.contributionDescription})
        </foreach>
    </insert>

    <insert id="batchProjectMember">
        insert into project_member( member_id, project_id, member_type, user_id, role_type, role_description, join_date, leave_date, contribution_percent) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.memberId}, #{item.projectId}, #{item.memberType}, #{item.userId}, #{item.roleType}, #{item.roleDescription}, #{item.joinDate}, #{item.leaveDate}, #{item.contributionPercent})
        </foreach>
    </insert>

    <delete id="deleteProjectMemberByProjectIds" parameterType="String">
        delete from project_member where project_id in 
        <foreach item="projectId" collection="array" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </delete>

    <delete id="deleteProjectMemberByProjectId" parameterType="Long">
        delete from project_member where project_id = #{projectId}
    </delete>

    <insert id="batchFundingRecord">
        insert into funding_record( funding_id, project_id, amount, allocation_date, funding_source, funding_type, status) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.fundingId}, #{item.projectId}, #{item.amount}, #{item.allocationDate}, #{item.fundingSource}, #{item.fundingType}, #{item.status})
        </foreach>
    </insert>

    <delete id="deleteFundingRecordByProjectIds" parameterType="String">
        delete from funding_record where project_id in 
        <foreach item="projectId" collection="array" open="(" separator="," close=")">
            #{projectId}
        </foreach>
    </delete>

    <delete id="deleteFundingRecordByProjectId" parameterType="Long">
        delete from funding_record where project_id = #{projectId}
    </delete>
</mapper>