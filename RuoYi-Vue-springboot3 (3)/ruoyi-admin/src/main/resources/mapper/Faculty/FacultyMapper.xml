<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.Faculty.mapper.FacultyMapper">
    
    <resultMap type="Faculty" id="FacultyResult">
        <result property="facultyId"    column="faculty_id"    />
        <result property="facultyNumber"    column="faculty_number"    />
        <result property="name"    column="name"    />
        <result property="title"    column="title"    />
        <result property="researchField"    column="research_field"    />
        <result property="departmentId"    column="department_id"    />
        <result property="departmentName"    column="department_name"    />
        <result property="employmentDate"    column="employment_date"    />
        <result property="status"    column="status"    />
        <result property="paperCount"    column="paper_count"    />
        <result property="projectCount"    column="project_count"    />
        <result property="totalFunding"    column="total_funding"    />
    </resultMap>

    <sql id="selectFacultyVo">
        select f.faculty_id, f.faculty_number, f.name, f.title, f.research_field, f.department_id, d.department_name, f.employment_date, f.status, f.paper_count, f.project_count, f.total_funding 
        from faculty f
        left join department d on f.department_id = d.department_id
    </sql>

    <select id="selectFacultyList" parameterType="Faculty" resultMap="FacultyResult">
        <include refid="selectFacultyVo"/>
        <where>  
            <if test="facultyNumber != null  and facultyNumber != ''"> and faculty_number = #{facultyNumber}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="researchField != null  and researchField != ''"> and research_field = #{researchField}</if>
            <if test="departmentId != null "> and department_id = #{departmentId}</if>
            <if test="employmentDate != null "> and employment_date = #{employmentDate}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectFacultyByFacultyId" parameterType="Long" resultMap="FacultyResult">
        <include refid="selectFacultyVo"/>
        where faculty_id = #{facultyId}
    </select>

    <select id="selectFacultyByFacultyNumber" parameterType="String" resultMap="FacultyResult">
        <include refid="selectFacultyVo"/>
        where faculty_number = #{facultyNumber}
    </select>

    <insert id="insertFaculty" parameterType="Faculty">
        insert into faculty
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="facultyId != null">faculty_id,</if>
            <if test="facultyNumber != null and facultyNumber != ''">faculty_number,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="title != null">title,</if>
            <if test="researchField != null">research_field,</if>
            <if test="departmentId != null">department_id,</if>
            <if test="employmentDate != null">employment_date,</if>
            <if test="status != null">status,</if>
            <if test="paperCount != null">paper_count,</if>
            <if test="projectCount != null">project_count,</if>
            <if test="totalFunding != null">total_funding,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="facultyId != null">#{facultyId},</if>
            <if test="facultyNumber != null and facultyNumber != ''">#{facultyNumber},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="title != null">#{title},</if>
            <if test="researchField != null">#{researchField},</if>
            <if test="departmentId != null">#{departmentId},</if>
            <if test="employmentDate != null">#{employmentDate},</if>
            <if test="status != null">#{status},</if>
            <if test="paperCount != null">#{paperCount},</if>
            <if test="projectCount != null">#{projectCount},</if>
            <if test="totalFunding != null">#{totalFunding},</if>
         </trim>
    </insert>

    <update id="updateFaculty" parameterType="Faculty">
        update faculty
        <trim prefix="SET" suffixOverrides=",">
            <if test="facultyNumber != null and facultyNumber != ''">faculty_number = #{facultyNumber},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="title != null">title = #{title},</if>
            <if test="researchField != null">research_field = #{researchField},</if>
            <if test="departmentId != null">department_id = #{departmentId},</if>
            <if test="employmentDate != null">employment_date = #{employmentDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="paperCount != null">paper_count = #{paperCount},</if>
            <if test="projectCount != null">project_count = #{projectCount},</if>
            <if test="totalFunding != null">total_funding = #{totalFunding},</if>
        </trim>
        where faculty_id = #{facultyId}
    </update>

    <delete id="deleteFacultyByFacultyId" parameterType="Long">
        delete from faculty where faculty_id = #{facultyId}
    </delete>

    <delete id="deleteFacultyByFacultyIds" parameterType="String">
        delete from faculty where faculty_id in 
        <foreach item="facultyId" collection="array" open="(" separator="," close=")">
            #{facultyId}
        </foreach>
    </delete>
</mapper>